# ─────────────────────────────────────────────────────────────
# AIFM — Variables de entorno de ejemplo
# Copiar a .env y rellenar con valores reales
# ─────────────────────────────────────────────────────────────

# Base de datos PostgreSQL
DATABASE_URL="postgresql://aifm_user:aifm_pass@localhost:5432/aifm_db"

# Redis
REDIS_URL="redis://:aifm_redis_pass@localhost:6379/0"

# NextAuth (Next.js)
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# URL del backend FastAPI (expuesta al browser)
NEXT_PUBLIC_API_URL="http://localhost:8000"
