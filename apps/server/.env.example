# ─────────────────────────────────────────────────────────────
# AIFM Server — Variables de entorno de ejemplo
# Copiar a .env y completar antes de arrancar el servidor
# ─────────────────────────────────────────────────────────────

APP_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production

# PostgreSQL (debe coincidir con docker-compose.yml)
DATABASE_URL=postgresql+asyncpg://aifm_user:aifm_pass@localhost:5432/aifm_db

# Redis (debe coincidir con docker-compose.yml)
REDIS_URL=redis://:aifm_redis_pass@localhost:6379/0

# CORS — añadir más orígenes separados por coma si es necesario
CORS_ORIGINS=http://localhost:3000
